{
  "manifest_version": 3,
  "name": "Bubble Bookmarks",
  "version": "1.0.0",
  "description": "Save pages as glowing bubble bookmarks.",
  "permissions": ["contextMenus", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
